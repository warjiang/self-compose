############################
##       Global           ##
############################
# COMPOSE_PROFILES (required to start any service):
#   core:     openclaw-gateway only
#   minimal:  openclaw-gateway + all-in-one-sandbox
#   all:      openclaw-gateway + all-in-one-sandbox + clash
# Usage: docker compose up (reads COMPOSE_PROFILES from .env)
#        or override: docker compose up --profile <name>
COMPOSE_PROFILES=all

############################
##       OpenClaw         ##
############################
# OpenClaw Docker Environment Variables Configuration Example
# Copy this file to .env and modify the values accordingly

# Docker image config
OPENCLAW_IMAGE=justlikemaki/openclaw-docker-cn-im:latest

# Config sync toggle
# Whether to automatically sync environment variables to openclaw.json (true/false)
# If you manually maintain openclaw.json, set this to false
SYNC_OPENCLAW_CONFIG=true
# Whether to automatically sync model config to openclaw.json (true/false)
# Only effective when SYNC_OPENCLAW_CONFIG=true; if you manually modified model settings in openclaw.json, set this to false
SYNC_MODEL_CONFIG=true

# Provider 1 (default)
# Main model ID (supports multiple, separated by comma, the first one will be the default model)
MODEL_ID=model id
# Explicitly specify agents.defaults.model.primary (optional)
# When empty, defaults to default/${first value of MODEL_ID}
# To switch to another provider's model, fill in the full provider/model, e.g. aliyun/qwen3.5-plus
PRIMARY_MODEL=
# Image model ID (optional, empty uses MODEL_ID, supports provider/model format)
# To switch to another provider's image model, fill in the full provider/model, e.g. aliyun/qwen-vl-max
IMAGE_MODEL_ID=
BASE_URL=http://xxxxx/v1
API_KEY=123456
# API protocol type: openai-completions or anthropic-messages
API_PROTOCOL=openai-completions
# Model context window size
CONTEXT_WINDOW=200000
# Model max output tokens
MAX_TOKENS=8192

# Provider 2 (optional)
# MODEL2_NAME=model2
# MODEL2_MODEL_ID=model id1,model id2
# MODEL2_BASE_URL=http://xxxxx/v1
# MODEL2_API_KEY=123456
# MODEL2_PROTOCOL=openai-completions
# MODEL2_CONTEXT_WINDOW=200000
# MODEL2_MAX_TOKENS=8192

# Channel common config
# Default DM policy: open/closed/friend-only
DM_POLICY=open
# Default group policy: open/closed
GROUP_POLICY=open
# Default allowed sources (multiple separated by comma, * means all)
ALLOW_FROM=*

# Telegram config (optional, empty means disabled)
TELEGRAM_BOT_TOKEN=
TELEGRAM_DM_POLICY=
TELEGRAM_ALLOW_FROM=
TELEGRAM_GROUP_POLICY=

# Feishu (Lark) config (optional, empty means disabled)
# Method 1: Single account shortcut config, will be auto-synced to channels.feishu.accounts.${FEISHU_DEFAULT_ACCOUNT}
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DEFAULT_ACCOUNT=default
FEISHU_BOT_NAME=OpenClaw Bot
FEISHU_REPLY_MODE=auto
FEISHU_THREAD_SESSION=true
FEISHU_DOMAIN=
# Method 2: Multi-account JSON (recommended, single line)
# Example: {"default":{"appId":"cli_xxx","appSecret":"xxx","botName":"OpenClaw Bot"},"work":{"appId":"cli_work_yyy","appSecret":"work_secret_yyy","botName":"Work Bot","dmPolicy":"allowlist","allowFrom":["ou_5b990e213988b9bcf396f955a50b2a22","ou_1234567890abcdef"]},"support":{"appId":"cli_support_zzz","appSecret":"support_secret_zzz","botName":"Support Bot","dmPolicy":"open","allowFrom":["*"]}}
FEISHU_ACCOUNTS_JSON=
# Feishu group rules JSON (optional, single line)
# Example: {"*":{"requireMention":true},"oc_83e1c0d069b94efc09ad22e05bc06365":{"requireMention":false,"groupPolicy":"open"},"oc_dev_123456789":{"requireMention":false,"groupPolicy":"allowlist","allowFrom":["ou_dev_001","ou_dev_002"]}}
FEISHU_GROUPS_JSON=
FEISHU_DM_POLICY=
FEISHU_ALLOW_FROM=
FEISHU_GROUP_POLICY=
FEISHU_GROUP_ALLOW_FROM=
# Enable Feishu official plugin (true/false)
FEISHU_OFFICIAL_PLUGIN_ENABLED=false
# Feishu specific config (optional)
FEISHU_STREAMING=true
FEISHU_FOOTER_ELAPSED=true
FEISHU_FOOTER_STATUS=true
FEISHU_REQUIRE_MENTION=true

# Dingtalk config (optional, empty means disabled)
# Method 1: Single bot shortcut config, will be auto-synced to channels.dingtalk.accounts.default
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ROBOT_CODE=
DINGTALK_DM_POLICY=
DINGTALK_GROUP_POLICY=
DINGTALK_ALLOW_FROM=
DINGTALK_CORP_ID=
DINGTALK_AGENT_ID=
DINGTALK_MESSAGE_TYPE=markdown
DINGTALK_CARD_TEMPLATE_ID=
DINGTALK_CARD_TEMPLATE_KEY=
DINGTALK_MAX_RECONNECT_CYCLES=
DINGTALK_DEBUG=false
DINGTALK_JOURNAL_TTL_DAYS=
DINGTALK_SHOW_THINKING=false
DINGTALK_THINKING_MESSAGE=
DINGTALK_ASYNC_MODE=false
DINGTALK_ASYNC_ACK_TEXT=
# Method 2: Multi-bot JSON (recommended, single line)
# Example: {"bot_1":{"clientId":"your-client-id-1","clientSecret":"your-client-secret-1","robotCode":"your-robot-code-1","corpId":"your-corp-id","agentId":"your-dingtalk-agent-id-1","dmPolicy":"open","groupPolicy":"open","messageType":"card","cardTemplateId":"your-card-template-id.schema","cardTemplateKey":"content","maxReconnectCycles":10,"allowFrom":["*"]},"bot_2":{"clientId":"your-client-id-2","clientSecret":"your-client-secret-2","robotCode":"your-robot-code-2","corpId":"your-corp-id","agentId":"your-dingtalk-agent-id-2","dmPolicy":"open","groupPolicy":"open","messageType":"markdown","allowFrom":["*"]}}
DINGTALK_ACCOUNTS_JSON=

# QQ bot config (optional, empty means disabled)
# Method 1: Single bot (legacy format compatible), will be auto-synced to channels.qqbot.accounts.default
QQBOT_APP_ID=
QQBOT_CLIENT_SECRET=
QQBOT_DM_POLICY=
QQBOT_ALLOW_FROM=
QQBOT_GROUP_POLICY=
# Method 2: Multi-bot JSON, supports default/bot2/bot3... independent config (will deep merge with existing config)
# Note: JSON in .env needs to be single line
# Example: {"default":{"enabled":true,"appId":"111111111","clientSecret":"secret-of-bot-1"},"bot2":{"enabled":true,"appId":"222222222","clientSecret":"secret-of-bot-2"},"bot3":{"enabled":true,"appId":"333333333","clientSecret":"secret-of-bot-3"}}
QQBOT_BOTS_JSON=

# WeCom (Enterprise WeChat) config (optional, empty means disabled)
# Current recommended format: multi-account structure, top-level shared fields will be merged into each account
WECOM_DEFAULT_ACCOUNT=open
WECOM_COMMANDS_ENABLED=true
WECOM_COMMANDS_ALLOWLIST=/new,/compact,/help,/status
WECOM_BOT_ID=
WECOM_SECRET=
# Single account shortcut config: will be written to channels.wecom.${WECOM_DEFAULT_ACCOUNT}
WECOM_ADMIN_USERS=admin-userid
WECOM_DYNAMIC_AGENTS_ENABLED=true
WECOM_DYNAMIC_AGENTS_ADMIN_BYPASS=false
WECOM_WELCOME_MESSAGE=
WECOM_SEND_THINKING_MESSAGE=false
WECOM_DM_POLICY=
WECOM_ALLOW_FROM=
WECOM_GROUP_POLICY=
WECOM_GROUP_ALLOW_FROM=
WECOM_WORKSPACE_TEMPLATE=
WECOM_AGENT_CORP_ID=
WECOM_AGENT_CORP_SECRET=
WECOM_AGENT_ID=
WECOM_WEBHOOKS_JSON=
WECOM_DM_CREATE_AGENT_ON_FIRST_MESSAGE=true
WECOM_GROUP_CHAT_ENABLED=true
WECOM_GROUP_CHAT_REQUIRE_MENTION=true
WECOM_GROUP_CHAT_MENTION_PATTERNS=@
WECOM_NETWORK_EGRESS_PROXY_URL=
WECOM_NETWORK_API_BASE_URL=
# Multi-account JSON (recommended)
# Example: {"open":{"botId":"aib-open-xxx","secret":"secret-open-xxx","dmPolicy":"open"},"support":{"botId":"aib-support-xxx","secret":"secret-support-xxx","dmPolicy":"pairing","agent":{"corpId":"wwxxxxxxxxxxxxxxxx","corpSecret":"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx","agentId":1000002},"webhooks":{"ops":"https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx"}}}
WECOM_ACCOUNTS_JSON=

# NapCat (OneBot v11) config (optional, empty means disabled)
# NapCat reverse WS listening port (NapCat actively connects to this port)
NAPCAT_REVERSE_WS_PORT=
NAPCAT_DM_POLICY=
NAPCAT_ALLOW_FROM=
NAPCAT_GROUP_POLICY=
# NapCat HTTP API address (optional, for actively sending messages)
NAPCAT_HTTP_URL=
# Connection auth token (keep consistent with NapCat side)
NAPCAT_ACCESS_TOKEN=
# Admin user IDs, multiple separated by comma
NAPCAT_ADMINS=

# Workspace config (do not change)
WORKSPACE=/home/node/.openclaw/workspace

# Mount directory config (modify according to actual situation)
# OpenClaw data directory (contains config files, workspace, and all other data)
OPENCLAW_DATA_DIR=~/.openclaw

# Optional: container startup user UID:GID
# Default 0:0 (root) for init.sh to automatically fix mounted directory permissions, then drop privileges to node to start service
# To align with host user, can set to 1000:1000 or $(id -u):$(id -g) on Linux
OPENCLAW_RUN_USER=0:0

# Gateway config
## Gateway token for authentication (modify according to actual situation)
OPENCLAW_GATEWAY_TOKEN=123456
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_MODE=local
# Allowed origin domains, multiple separated by comma
OPENCLAW_GATEWAY_ALLOWED_ORIGINS=http://localhost
# Allow insecure auth (e.g. http), optional true/false
OPENCLAW_GATEWAY_ALLOW_INSECURE_AUTH=true
# Danger: disable device auth (e.g. in Docker environment where device info cannot be obtained), optional true/false
OPENCLAW_GATEWAY_DANGEROUSLY_DISABLE_DEVICE_AUTH=false
# Gateway auth mode, optional token
OPENCLAW_GATEWAY_AUTH_MODE=token
# Plugin global control
OPENCLAW_PLUGINS_ENABLED=true

# Tools config
# Complete tools config JSON (optional)
# Example: {"profile":"full","sessions":{"visibility":"all"},"fs":{"workspaceOnly":true}}
OPENCLAW_TOOLS_JSON=



############################
##       Clash            ##
############################
# uncommnet the following line if you want to use private registry
# REGISTRY={your-registry-url}
