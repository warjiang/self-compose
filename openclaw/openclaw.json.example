        "models": [
          {
            "id": "model id",
            "name": "model name",
            "reasoning": false,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      },
      "openai-example": {
        "baseUrl": "http://localhost:3000/v1",
        "apiKey": "your-api-key",
